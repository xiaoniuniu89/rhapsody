<section class="rhapsody-panel">
  <header class="rhapsody-header">
    <div class="scene-info">
      <i class="fa-solid fa-map"></i>
      <strong>{{#if activeScene}}{{activeScene.name}}{{else}}No active scene{{/if}}</strong>
    </div>
    <div class="asset-health">
      <i class="fa-solid fa-database"></i>
      {{assets.status.maps}} maps · {{assets.status.audio}} audio · {{assets.status.tokens}} tokens
    </div>
  </header>

  <section class="rhapsody-voice-section" data-voice-status="{{voice.status}}">
    <div class="rhapsody-voice-status">
      <span class="voice-indicator voice-{{voice.status}}"></span>
      <span class="voice-label">{{voice.statusLabel}}</span>
      {{#if voice.speaking}}
        <button type="button" data-action="interruptTts" class="voice-interrupt">Interrupt</button>
      {{/if}}
    </div>
    <ol class="rhapsody-voice-transcript">
      {{#each voice.transcript}}
        <li class="voice-line voice-{{this.role}}">
          <span class="voice-role">{{this.role}}</span>
          <span class="voice-text">{{this.text}}</span>
        </li>
      {{/each}}
      {{#unless voice.transcript.length}}
        <li class="voice-line voice-empty"><em>No utterances yet. Hold the bound key (default <code>`</code>) to talk.</em></li>
      {{/unless}}
    </ol>
  </section>

  <details class="rhapsody-debug-disclosure">
    <summary>Debug Tools</summary>

    <section class="rhapsody-debug-section">
      <h3>Quick Turn</h3>
      <form class="rhapsody-turn-form" onsubmit="return false;">
        <textarea name="player-message" rows="2" placeholder="Send a manual turn..."></textarea>
        <button type="button" data-action="sendTurn">Send Turn</button>
      </form>

      {{#if turnResult}}
        <div class="rhapsody-turn-result">
          <div class="rhapsody-narration">{{{turnResult.narration}}}</div>
          {{#if turnResult.movesTaken}}
            <details class="rhapsody-moves">
              <summary>Moves taken ({{turnResult.movesTaken.length}})</summary>
              <ul>
                {{#each turnResult.movesTaken}}
                  <li class="{{#if this.ok}}ok{{else}}error{{/if}}">
                    <strong>{{this.name}}</strong>: {{this.log}}
                    <pre>{{#if this.args}}{{{json this.args}}}{{/if}}</pre>
                  </li>
                {{/each}}
              </ul>
            </details>
          {{/if}}
        </div>
      {{/if}}
    </section>

    <section class="rhapsody-debug-section">
      <h3>World State</h3>
      <div class="state-clocks">
        {{#each state.clocks}}
          <div class="state-clock">
            <div class="state-clock-head">
              <strong>{{this.name}}</strong>
              <span class="state-clock-count">{{this.filled}}/{{this.segments}}</span>
            </div>
            <div class="state-clock-bar">
              {{#each this.cells}}<span class="cell {{#if this}}filled{{/if}}"></span>{{/each}}
            </div>
            <div class="state-clock-actions">
              <button type="button" data-action="advanceClock" data-clock="{{this.name}}" data-delta="-1">−</button>
              <button type="button" data-action="advanceClock" data-clock="{{this.name}}" data-delta="1">+</button>
              <button type="button" data-action="removeClock" data-clock="{{this.name}}">×</button>
            </div>
          </div>
        {{/each}}
        <form class="state-clock-form" onsubmit="return false;">
          <input type="text" name="clock-name" placeholder="New clock..." />
          <input type="number" name="clock-segments" value="4" style="width: 3em;" />
          <button type="button" data-action="createClock">Add</button>
        </form>
      </div>

      <div class="state-dispositions">
        {{#each state.dispositions}}
          <div class="state-disp">
            <strong>{{this.npc}}</strong>
            <span class="state-disp-scale">
              {{#each this.cells}}<span class="cell {{#if this.active}}active{{/if}} {{this.tone}}">{{this.label}}</span>{{/each}}
            </span>
            <button type="button" data-action="removeDisposition" data-npc="{{this.npc}}">×</button>
          </div>
        {{/each}}
        <form class="state-disp-form" onsubmit="return false;">
          <input type="text" name="disp-npc" placeholder="NPC name" />
          <button type="button" data-action="shiftDisposition">Track</button>
        </form>
      </div>
    </section>

    <section class="rhapsody-debug-section">
      <h3>Memory</h3>
      <form class="rhapsody-memory-write-form" onsubmit="return false;">
        <select name="write-scope">
          <option value="bible">Bible</option>
          <option value="journal">Journal</option>
        </select>
        <input type="text" name="write-name" placeholder="Page name" />
        <textarea name="write-public" rows="2" placeholder="Public content"></textarea>
        <textarea name="write-private" rows="2" placeholder="Private content (Bible only)"></textarea>
        <button type="button" data-action="writePage">Write</button>
      </form>

      <form class="rhapsody-memory-form" onsubmit="return false;">
        <select name="memory-scope">
          <option value="bible">Bible</option>
          <option value="journal">Journal</option>
        </select>
        <input type="text" name="memory-name" placeholder="Read page..." />
        <button type="button" data-action="readPage">Read</button>
      </form>

      {{#if lastPage}}
        <div class="rhapsody-page">
          <strong>{{lastPage.name}}</strong>
          <div class="page-public">{{{lastPage.public}}}</div>
          {{#if lastPage.private}}
            <div class="page-private"><em>{{lastPage.private}}</em></div>
          {{/if}}
        </div>
      {{/if}}
    </section>

    <section class="rhapsody-debug-section">
      <h3>Scene Contract</h3>
      {{#if activeScene}}
        <form class="rhapsody-contract-form" onsubmit="return false;">
          <input type="text" name="contract-question" value="{{contract.question}}" placeholder="Goal/Question" />
          <textarea name="contract-onOffer" rows="2" placeholder="On Offer (one per line)">{{#each contract.onOffer}}{{this.text}}&#10;{{/each}}</textarea>
          <textarea name="contract-hidden" rows="2" placeholder="Hidden (one per line)">{{#each contract.hidden}}{{this}}&#10;{{/each}}</textarea>
          <button type="button" data-action="saveContract">Save</button>
        </form>
      {{else}}
        <p>No active scene.</p>
      {{/if}}
    </section>

    <section class="rhapsody-debug-section">
      <h3>Rules RAG</h3>
      <div class="rules-pack-list">
        {{#each rules.allPacks}}
          <label><input type="checkbox" name="rules-pack" value="{{this.id}}" {{#if this.selected}}checked{{/if}}> {{this.label}}</label>
        {{/each}}
      </div>
      <button type="button" data-action="saveRulesSettings">Save Packs</button>
      <button type="button" data-action="reindexRules">Reindex</button>
      
      <form class="rules-query-form" onsubmit="return false;">
        <input type="text" name="rules-query" placeholder="Ask a rules question..." />
        <button type="button" data-action="queryRules">Query</button>
      </form>
      {{#if rules.queryResults}}
        <div class="rules-results">
          {{#each rules.queryResults}}{{{this.citation}}} ({{this.similarity}}%) {{/each}}
        </div>
      {{/if}}
    </section>

    <section class="rhapsody-debug-section">
      <h3>Stagecraft Manual</h3>
      <div class="stagecraft-form">
        <input type="text" name="map-query" placeholder="Map query" />
        <button type="button" data-action="setMap">Map</button>
      </div>
      <div class="stagecraft-form">
        <input type="text" name="audio-query" placeholder="Audio query" />
        <button type="button" data-action="playAudio">Play</button>
        <button type="button" data-action="stopAudio">Stop</button>
      </div>
      <div class="lighting-presets">
        <button type="button" data-action="setLighting" data-preset="day">Day</button>
        <button type="button" data-action="setLighting" data-preset="night">Night</button>
      </div>
    </section>

    <section class="rhapsody-debug-section">
      <h3>Assets Index</h3>
      <button type="button" data-action="reindexAssets">Reindex Assets</button>
      <form class="assets-query-form" onsubmit="return false;">
        <input type="text" name="assets-query" placeholder="Search..." />
        <button type="button" data-action="queryAssets">Test</button>
      </form>
    </section>

    <section class="rhapsody-debug-section">
      <h3>System</h3>
      <button type="button" data-action="testConnection">Test OpenAI</button>
      {{#if lastResponse}}<pre>{{lastResponse}}</pre>{{/if}}
    </section>

    {{#if lastPageError}}<p class="rhapsody-error">{{lastPageError}}</p>{{/if}}
    {{#if lastPageSuccess}}<p class="rhapsody-success">{{lastPageSuccess}}</p>{{/if}}
  </details>
</section>
